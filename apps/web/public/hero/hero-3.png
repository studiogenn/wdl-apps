  // ─── Logging ───────────────────────────────────────────────────────

  function log() {
    if (!DEBUG) return;
    console.log.apply(console, ['[WDL]'].concat(Array.prototype.slice.call(arguments)));
  }

  // ─── Utilities ─────────────────────────────────────────────────────

  function safeJSON(str) {
    try { return JSON.parse(str); } catch (e) { return null; }
  }

  function getPageContext() {
    return {
      page_path: window.location.pathname,
      page_title: document.title,
      page_url: window.location.href
    };
  }

  // ─── PostHog Helpers ───────────────────────────────────────────────

  function waitForPostHog(cb) {
    if (typeof posthog !== 'undefined' && posthog.capture) { cb(); }
    else { setTimeout(function () { waitForPostHog(cb); }, 200); }
  }

  function track(eventName, props) {
    waitForPostHog(function () {
      posthog.capture(eventName, Object.assign({ _source: 'wdl_tracker' }, getPageContext(), props || {}));
    });
    log('Event:', eventName, props);
  }


  // ═════════════════════════════════════════════════════════════════════
  // 1. IDENTITY STITCHING
  // ═════════════════════════════════════════════════════════════════════
  //
  // Priority: cc_uid (CleanCloud customer ID) > email
  // Flow:
  //   1. Anonymous → PostHog assigns anon_id
  //   2. Email captured (form or widget) → identify(email)
  //   3. CleanCloud login → identify(cc_uid), merges email → cc_uid

  function identifyWithUID(uid) {
    if (!uid || state.uid === uid) return;
    state.uid = uid;
    waitForPostHog(function () {
      var props = { cleancloud_id: uid };
      if (state.email) props.email = state.email;
      posthog.identify(uid, props, { first_seen: new Date().toISOString() });
    });
    log('Identified (cc_uid):', uid);
  }

  function identifyWithEmail(email, properties) {
    if (!email) return;
    state.email = email;
    waitForPostHog(function () {
      if (state.uid) {
        posthog.setPersonProperties(Object.assign({ email: email }, properties || {}));
      } else {
        posthog.identify(email, Object.assign({ email: email }, properties || {}));
      }
    });
    log('Identified (email):', email);
  }

  function resetIdentity() {
    waitForPostHog(function () { posthog.reset(); });
    state.uid = null;
    state.email = null;
    log('Identity reset');
  }


  // ═════════════════════════════════════════════════════════════════════
  // 2. CLEANCLOUD WIDGET TRACKING (inline JS, not iframe)
  // ═════════════════════════════════════════════════════════════════════

  // ─── 2A: localStorage Proxy ────────────────────────────────────────

  function installStorageProxy() {
    var handler = {
      get: function (target, prop) {
        if (prop === 'setItem') {
          return function (key, val) {
            onStorageWrite(key, val);
            return target.setItem(key, val);
          };
        }
        if (prop === 'removeItem') {
          return function (key) {
            onStorageRemove(key);
            return target.removeItem(key);
          };
        }
        if (prop === 'clear') {
          return function () {
            onStorageClear();
            return target.clear();
          };
        }
        var value = target[prop];
        return typeof value === 'function' ? value.bind(target) : value;
      },
      set: function (target, prop, value) {
        onStorageWrite(prop, value);
        target.setItem(prop, value);
        return true;
      }
    };

    try {
      Object.defineProperty(window, 'localStorage', {
        value: new Proxy(originalLS, handler),
        configurable: true,
        writable: false
      });
      log('localStorage proxy installed');
    } catch (e) {
      console.error('[WDL] localStorage proxy failed:', e);
    }
  }

  function onStorageWrite(key, value) {
    if (key === CC_KEYS.uid) {
      identifyWithUID(value);
      return;
    }

    if (key === CC_KEYS.customer) {
      var customer = safeJSON(value);
      if (customer) {
        var email = customer.email || customer.emailAddress || null;
        var name = customer.name || customer.fullName || null;
        var phone = customer.phone || customer.phoneNumber || null;
        if (email) identifyWithEmail(email, { name: name, phone: phone });
        track('cc_customer_loaded', { has_email: !!email, has_phone: !!phone });
      }
      return;
    }

    if (key === CC_KEYS.order) {
      handleOrderData(value);
      return;
    }
  }

  function onStorageRemove(key) {
    if (key === CC_KEYS.uid) resetIdentity();
    if (key === CC_KEYS.order) {
      track('order_cleared', { order_id: state.orderId });
      state.orderId = null;
      state.orderStarted = false;
      state.orderItems = 0;
    }
  }

  function onStorageClear() {
    resetIdentity();
    state.orderId = null;
    state.orderStarted = false;
    state.orderItems = 0;
  }

  function handleOrderData(raw) {
    var parsed = safeJSON(raw);
    if (!parsed || !parsed.order) return;

    var order = parsed.order;
    var orderId = order.id || order.orderId || null;

    if (orderId && orderId !== state.orderId) {
      state.orderId = orderId;
      state.orderStarted = false;
    }

    if (!state.orderStarted) {
      state.orderStarted = true;
      track('order_started', { order_id: orderId });
    }

    var items = order.items || order.orderItems || [];
    var itemCount = Array.isArray(items) ? items.length : 0;
    if (itemCount !== state.orderItems) {
      state.orderItems = itemCount;
      track('order_updated', {
        order_id: orderId,
        item_count: itemCount,
        subtotal: order.subtotal || order.total || null,
        service_type: order.serviceType || order.service || null,
        has_premium_care: !!(order.premiumCare || order.delicates),
        tip_amount: order.tip || order.tipAmount || null,
        promo_code: order.promoCode || null
      });
    }
  }

  // ─── 2B: CleanCloud API Intercept ──────────────────────────────────

  var originalFetch = window.fetch;
  var originalXHROpen = XMLHttpRequest.prototype.open;
  var originalXHRSend = XMLHttpRequest.prototype.send;

  function isCleanCloudURL(url) {
    if (!url) return false;
    return url.toLowerCase().indexOf('cleancloud') !== -1;
  }

  function extractEndpoint(url) {
    try { return new URL(url, window.location.origin).pathname; } catch (e) { return url; }
  }

  function installNetworkInterceptors() {
    window.fetch = function (input, init) {
      var url = typeof input === 'string' ? input : (input && input.url) || '';
      var method = (init && init.method) || 'GET';

      if (isCleanCloudURL(url)) {
        var endpoint = extractEndpoint(url);
        track('cc_api_call', { method: method, endpoint: endpoint });

        return originalFetch.apply(this, arguments).then(function (response) {
          handleAPIResponse(method, endpoint, response.status);
          return response;
        });
      }
      return originalFetch.apply(this, arguments);
    };

    XMLHttpRequest.prototype.open = function (method, url) {
      this._wdlMethod = method;
      this._wdlUrl = url;
      return originalXHROpen.apply(this, arguments);
    };

    XMLHttpRequest.prototype.send = function (body) {
      var xhr = this;
      var url = xhr._wdlUrl || '';
      var method = xhr._wdlMethod || 'GET';

      if (isCleanCloudURL(url)) {
        var endpoint = extractEndpoint(url);
        track('cc_api_call', { method: method, endpoint: endpoint });
        xhr.addEventListener('load', function () {
          handleAPIResponse(method, endpoint, xhr.status);
        });
      }
      return originalXHRSend.apply(this, arguments);
    };

    log('Network interceptors installed');
  }

  function handleAPIResponse(method, endpoint, status) {
    var ep = endpoint.toLowerCase();

    if (method === 'POST' && (ep.indexOf('/order') !== -1 || ep.indexOf('/checkout') !== -1)) {
      if (status >= 200 && status < 300) {
        track('order_completed', { order_id: state.orderId, item_count: state.orderItems });
      } else {
        track('order_failed', { order_id: state.orderId, status: status });
      }
    }

    if (ep.indexOf('/login') !== -1 || ep.indexOf('/auth') !== -1 || ep.indexOf('/signin') !== -1) {
      if (status >= 200 && status < 300) track('cc_login', { method: method });
    }

    if (method === 'POST' && (ep.indexOf('/register') !== -1 || ep.indexOf('/signup') !== -1)) {
      if (status >= 200 && status < 300) track('cc_signup', {});
    }
  }

  // ─── 2C: Widget Step Tracking via DOM ─────────────────────────────

  function installWidgetStepTracker() {
    var container = document.getElementById('myStoreContainer');
    if (!container) return;

    var observer = new MutationObserver(function () {
      var heading = container.querySelector('h1, h2, .__cc_heading, [class*="heading"]');
      var stepText = heading ? heading.textContent.trim().toLowerCase() : '';
      if (!stepText || stepText === state.lastStep) return;
      state.lastStep = stepText;

      var stepMap = {
        'welcome': 'widget_step_welcome',
        'sign in': 'widget_step_login',
        'log in': 'widget_step_login',
        'sign up': 'widget_step_signup',
        'register': 'widget_step_signup',
        'address': 'widget_step_address',
        'pickup': 'widget_step_schedule',
        'schedule': 'widget_step_schedule',
        'delivery': 'widget_step_schedule',
        'services': 'widget_step_services',
        'select': 'widget_step_services',
        'items': 'widget_step_items',
        'order details': 'widget_step_items',
        'review': 'widget_step_review',
        'confirm': 'widget_step_confirm',
        'payment': 'widget_step_payment',
        'thank': 'widget_step_complete',
        'success': 'widget_step_complete',
        'confirmed': 'widget_step_complete'
      };

      var eventName = null;
      var keys = Object.keys(stepMap);
      for (var i = 0; i < keys.length; i++) {
        if (stepText.indexOf(keys[i]) !== -1) {
          eventName = stepMap[keys[i]];
          break;
        }
      }

      track(eventName || 'widget_step_changed', {
        step_heading: stepText.substring(0, 80),
        order_id: state.orderId
      });
    });

    observer.observe(container, { childList: true, subtree: true, characterData: true });
    log('Widget step tracker installed');
  }


  // ═════════════════════════════════════════════════════════════════════
  // 3. SITE-WIDE TRACKING
  // ═════════════════════════════════════════════════════════════════════

  // ─── 3A: Scroll Depth ─────────────────────────────────────────────

  function trackScrollDepth() {
    state.scrollMarks = {};
    var ticking = false;

    window.addEventListener('scroll', function () {
      if (ticking) return;
      ticking = true;

      requestAnimationFrame(function () {
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        var docHeight = Math.max(
          document.body.scrollHeight,
          document.documentElement.scrollHeight
        ) - window.innerHeight;

        if (docHeight <= 0) { ticking = false; return; }
        var percent = Math.round((scrollTop / docHeight) * 100);

        SCROLL_THRESHOLDS.forEach(function (t) {
          if (percent >= t && !state.scrollMarks[t]) {
            state.scrollMarks[t] = true;
            track('scroll_depth', { depth_percent: t });
          }
        });
        ticking = false;
      });
    }, { passive: true });

    log('Scroll tracking installed');
  }

  // ─── 3B: Phone & Email Click Tracking ─────────────────────────────

  function trackIntentClicks() {
    document.addEventListener('click', function (e) {
      var target = e.target;
      while (target && target.tagName !== 'A') target = target.parentElement;
      if (!target) return;

      var href = target.href || '';
      var text = (target.textContent || '').trim().substring(0, 100);

      if (href.indexOf('tel:') === 0) {
        track('phone_clicked', {
          phone_number: href.replace('tel:', '').replace(/\s/g, ''),
          link_text: text
        });
      } else if (href.indexOf('mailto:') === 0) {
        track('email_clicked', {
          email_address: href.replace('mailto:', '').split('?')[0],
          link_text: text
        });
      } else if (href.match(/sms:|whatsapp:|wa\.me/i)) {
        track('messaging_clicked', { link_url: href, link_text: text });
      }
    }, true);

    log('Intent click tracking installed');
  }

  // ─── 3C: Elementor Form Submissions ────────────────────────────────

  function trackElementorForms() {
    function bindJQuery() {
      if (!window.jQuery) return false;

      jQuery(document).on('submit_success', '.elementor-form', function (event, response) {
        var $form = jQuery(this);
        var formName = $form.find('[name="form_name"]').val()
          || $form.closest('.elementor-widget').data('id')
          || 'unknown';

        var fields = {};
        $form.find('input, select, textarea').each(function () {
          var name = this.name || this.id || '';
          var value = this.value || '';
          if (name.match(/password|pass|pwd|credit|card|cvv|ssn|token|nonce|_wp/i)) return;
          if (this.type === 'hidden' && !name.match(/form_name|form_id/i)) return;
          if (name && value) fields[name] = value;
        });

        var email = fields.email || fields.your_email || fields.field_email || null;
        if (email) {
          identifyWithEmail(email, {
            first_name: fields.name || fields.first_name || fields.your_name || undefined,
            phone: fields.phone || fields.tel || fields.telephone || undefined
          });
        }

        track('form_submitted', {
          form_name: formName,
          has_email: !!email,
          has_phone: !!(fields.phone || fields.tel),
          field_count: Object.keys(fields).length
        });
      });

      jQuery(document).on('error', '.elementor-form', function () {
        track('form_error', {
          form_name: jQuery(this).find('[name="form_name"]').val() || 'unknown'
        });
      });

      return true;
    }

    if (!bindJQuery()) {
      var retries = 0;
      var interval = setInterval(function () {
        if (bindJQuery() || ++retries > 30) clearInterval(interval);
      }, 500);
    }
    log('Elementor form tracking installed');
  }

  // ─── 3D: Elementor Popup Tracking ─────────────────────────────────

  function trackElementorPopups() {
    var tracked = new Set();

    function bind() {
      if (!window.jQuery || !window.elementorProFrontend) return false;

      jQuery(document).on('elementor/popup/show', function (event, popupId) {
        if (tracked.has(popupId)) return;
        tracked.add(popupId);

        var el = document.getElementById('elementor-popup-modal-' + popupId);
        var title = el ? (el.querySelector('.elementor-heading-title') || {}).textContent || '' : '';

        track('popup_shown', {
          popup_id: popupId,
          popup_title: title.trim().substring(0, 100)
        });
      });

      jQuery(document).on('elementor/popup/hide', function (event, popupId) {
        track('popup_closed', { popup_id: popupId });
      });

      return true;
    }

    if (!bind()) {
      var retries = 0;
      var interval = setInterval(function () {
        if (bind() || ++retries > 30) clearInterval(interval);
      }, 500);
    }
    log('Popup tracking installed');
  }


  // ═════════════════════════════════════════════════════════════════════
  // INIT
  // ═════════════════════════════════════════════════════════════════════

  function init() {
    installStorageProxy();
    installNetworkInterceptors();

    function initDOM() {
      trackScrollDepth();
      trackIntentClicks();
      trackElementorForms();
      trackElementorPopups();
      setTimeout(installWidgetStepTracker, 2000);
    }

    if (document.body) {
      initDOM();
    } else {
      document.addEventListener('DOMContentLoaded', initDOM);
    }

    var existingUID = originalLS.getItem(CC_KEYS.uid);
    if (existingUID) identifyWithUID(existingUID);

    var existingOrder = safeJSON(originalLS.getItem(CC_KEYS.order));
    if (existingOrder && existingOrder.order) {
      state.orderId = existingOrder.order.id || existingOrder.order.orderId || null;
    }

    log('Initialized | Page:', window.location.pathname);
  }

  // ─── Debug API ─────────────────────────────────────────────────────
  window._wdl = {
    state: function () { console.table(state); return state; },
    reset: function () {
      resetIdentity();
      state.orderId = null;
      state.orderStarted = false;
      state.orderItems = 0;
      state.scrollMarks = {};
      state.lastStep = null;
    },
    debug: function (on) { DEBUG = on !== false; },
    track: track,
    identify: identifyWithUID,
    identifyFromForm: identifyWithEmail
  };

  init();

