{
  "expo": {
    "name": "We Deliver Laundry",
    "slug": "we-deliver-laundry",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wedeliverlaundry",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1227BE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wedeliver.laundry",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to find available pickup routes and show delivery tracking.",
        "NSCameraUsageDescription": "We use the camera to scan receipts or photograph items."
      }
    },
    "android": {
      "package": "com.wedeliver.laundry",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1227BE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9e7dd4cb-9030-4fee-b1d3-537a752fb292"
      }
    },
    "owner": "mattwfo"
  }
}
